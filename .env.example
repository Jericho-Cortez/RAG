# CORHack RAG - Variables d'environnement
# Copie ce fichier en .env et remplis tes valeurs
# cp .env.example .env

# Groq Cloud API (obligatoire) - https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_API_KEY_HERE

# Chemin vers ton vault Obsidian
# VAULT_PATH=C:\Users\YourUser\Documents\Mon Vault Obsidian

# Nom de la collection Qdrant (auto-généré si vide)
# COLLECTION_NAME=obsidian_MonVault

# URL Qdrant (par défaut: http://localhost:6333)
# QDRANT_URL=http://localhost:6333
